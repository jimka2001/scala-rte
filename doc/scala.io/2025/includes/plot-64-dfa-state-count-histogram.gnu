# 
set logscale x
set logscale y
set xlabel "DFA State Count" font ",15"
set ylabel "Frequency" font ",15"
set grid
set key font ',15'
set xtics font ',15'
set ytics font ',15'
set key horizontal bmargin
set title "DFA State Count Histogram 64-"
plot "-" using 1:2 with linespoints title "naive-mid samples=995",\
    "-" using 1:2 with linespoints title "naive-edge samples=978",\
    "-" using 1:2 with linespoints title "balanced samples=968"
