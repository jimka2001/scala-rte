\begin{frame}{Motivation}
  \begin{itemize}
  \item<1->{ Property-Based Testing (PBT) requires object generation.}

  \item<1->{ Select objects (uniformly?) from an infinite space $T$.

    \input{set-t}
}

  \item<2->{ Selecting uniformly in $T$ may be difficult, so we may prefer to sample in another space $S$, and then convert object $s\in S$ to $f(s) = t \in T$.

    \input{map-s-to-t}
}

  \item<3>{Sadly uniform selection in $S$
    may not deliver uniformity in $T$.}
    
  \end{itemize}
\end{frame}

\begin{frame}{Motivation}
  \only<1>{\input{map-s-to-t}}%
  \only<2>{\input{thought-balloon}}%

  \begin{itemize}
  \item OBSERVATION:  When we select $s\in S$ then generate $f(s)\in T$ we often find that $f(s)$ is  trivial.  
    
  \item GOAL: improve uniformity in $T$ by biasing the selection in $S$.

  \item<2>{ CONCRETELY: uniformly sample Finite Automata by:
    \begin{enumerate}
    \item  Biased sample of Regular Expressions
    \item  Convert Regular Expression to Finite Automaton
    \end{enumerate}
}
  \end{itemize}

\end{frame}

