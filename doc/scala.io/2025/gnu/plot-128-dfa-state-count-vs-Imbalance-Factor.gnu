# 
set logscale y
set xlabel "Imbalance-Factor" font ",15"
set ylabel "DFA state count" font ",15"
set grid
set key font ',10'
set xtics font ',15'
set ytics font ',15'
set style line 1 pt 7 ps 0.8
set style line 2 pt 7 ps 0.8
