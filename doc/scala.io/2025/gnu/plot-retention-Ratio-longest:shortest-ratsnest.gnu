    "-" using 1:2 with lines title "tree-split-mid 234 samples",\
    "-" using 1:2 with lines title "tree-split-edge 240 samples",\
    "-" using 1:2 with lines title "flajolet 236 samples",\
    "-" using 1:2 with lines title "comb 240 samples"
