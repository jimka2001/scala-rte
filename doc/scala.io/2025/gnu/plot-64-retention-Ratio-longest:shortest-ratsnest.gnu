    "-" using 1:2 with lines title "tree-split-mid 483 samples",\
    "-" using 1:2 with lines title "tree-split-edge 484 samples",\
    "-" using 1:2 with lines title "flajolet 483 samples",\
    "-" using 1:2 with lines title "comb 480 samples"
