# 
set logscale y
set xlabel "Ratio-longest-shortest" font ",10"
set ylabel "retention" font ",10"
set grid
set key font ',10'
set xtics font ',10'
set ytics font ',10'
set style line 1 pt 7 ps 0.2
set style line 2 pt 7 ps 0.2
set style line 3 pt 7 ps 0.2
set style line 4 pt 7 ps 0.2
set style line 5 pt 7 ps 0.2
set key horizontal bmargin
set title "Retention: Ratio node count per state count " font ",12"
plot "-" using 1:2 with points ls 1 title "tree-split-linear 233 samples",\
    "-" using 1:2 with points ls 2 title "tree-split-gauss 234 samples",\
    "-" using 1:2 with points ls 3 title "tree-split-inv-gauss 240 samples",\
    "-" using 1:2 with points ls 4 title "flajolet 236 samples",\
    "-" using 1:2 with points ls 5 title "comb 240 samples"
