# 
set logscale y
set xlabel "Aspect-Ratio" font ",15"
set ylabel "retention" font ",15"
set grid
set key font ',15'
set xtics font ',15'
set ytics font ',15'
set style line 1 pt 7 ps 0.8
set style line 2 pt 7 ps 0.8
set style line 3 pt 7 ps 0.8
